@page "/counter"
@inject ITranslaasService Translaas

<PageTitle>Counter</PageTitle>

<h1>@await Translaas.T("pages", "counter.title", "en")</h1>

<p role="status">@await Translaas.T("pages", "counter.current", "en"): <strong>@currentCount</strong></p>

<button class="btn btn-primary" @onclick="IncrementCount">
    @await Translaas.T("buttons", "increment", "en")
</button>

<p class="mt-3">
    @await Translaas.T("pages", "counter.description", "en")
</p>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
    }
}
