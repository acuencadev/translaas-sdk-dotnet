@page "/fetchdata"
@inject ITranslaasService Translaas

<PageTitle>Weather Forecast</PageTitle>

<h1>@weatherTitle</h1>

<p>@weatherDescription</p>

@if (forecasts == null)
{
    <p><em>@loadingText</em></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>@dateText</th>
                <th>@temperatureCText</th>
                <th>@temperatureFText</th>
                <th>@summaryText</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var forecast in forecasts)
            {
                <tr>
                    <td>@forecast.Date.ToShortDateString()</td>
                    <td>@forecast.TemperatureC</td>
                    <td>@forecast.TemperatureF</td>
                    <td>@forecast.Summary</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private WeatherForecast[]? forecasts;
    private string weatherTitle = string.Empty;
    private string weatherDescription = string.Empty;
    private string loadingText = string.Empty;
    private string dateText = string.Empty;
    private string temperatureCText = string.Empty;
    private string temperatureFText = string.Empty;
    private string summaryText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        // Load translations
        weatherTitle = await Translaas.T("pages", "weather.title", "en");
        weatherDescription = await Translaas.T("pages", "weather.description", "en");
        loadingText = await Translaas.T("common", "loading", "en");
        dateText = await Translaas.T("weather", "date", "en");
        temperatureCText = await Translaas.T("weather", "temperature.c", "en");
        temperatureFText = await Translaas.T("weather", "temperature.f", "en");
        summaryText = await Translaas.T("weather", "summary", "en");

        // Simulate async data loading
        await Task.Delay(500);
        
        var startDate = DateOnly.FromDateTime(DateTime.Now);
        forecasts = Enumerable.Range(1, 5).Select(index => new WeatherForecast
        {
            Date = startDate.AddDays(index),
            TemperatureC = Random.Shared.Next(-20, 55),
            Summary = $"Weather {index}"
        }).ToArray();
    }

    public class WeatherForecast
    {
        public DateOnly Date { get; set; }
        public int TemperatureC { get; set; }
        public string? Summary { get; set; }
        public int TemperatureF => 32 + (int)(TemperatureC / 0.5556);
    }
}
