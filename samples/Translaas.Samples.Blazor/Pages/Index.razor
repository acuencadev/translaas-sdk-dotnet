@page "/"
@using System.Collections.Generic
@using Translaas.Models
@using Translaas.Models.Responses
@inject ITranslaasService Translaas
@inject ITranslaasClient TranslaasClient

<PageTitle>Home</PageTitle>

<h1>@welcome</h1>

<p>@welcomeMessage</p>

<div class="row mt-5">
    <div class="col-md-12">
        <h2>Translation Examples</h2>
        
        <div class="card mb-3">
            <div class="card-header">
                <h3>1. Direct Service Injection</h3>
            </div>
            <div class="card-body">
                <p>Using injected <code>ITranslaasService</code>:</p>
                <pre><code>@@await Translaas.T("common", "welcome", LanguageCodes.English)</code></pre>
                <p>Result: @welcome</p>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <h3>2. Pluralization</h3>
            </div>
            <div class="card-body">
                <p>Using pluralization with the <code>number</code> parameter:</p>
                <pre><code>@@await Translaas.T("messages", "item", LanguageCodes.English, 1)
@@await Translaas.T("messages", "item", LanguageCodes.English, 5)</code></pre>
                <p>1 item: @itemSingular</p>
                <p>5 items: @itemPlural</p>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <h3>3. Named Parameters</h3>
            </div>
            <div class="card-body">
                <p>Using named parameters with <code>ITranslaasService.T()</code>:</p>
                <pre><code>var parameters = new Dictionary&lt;string, string&gt;
{
    { "userName", "John" },
    { "itemCount", "5" }
};
@@await Translaas.T("messages", "greeting", LanguageCodes.English, parameters: parameters)</code></pre>
                <p>Translation with parameters: @greetingWithParams</p>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <h3>4. Combining Number and Named Parameters</h3>
            </div>
            <div class="card-body">
                <p>Combining <code>number</code> and named parameters:</p>
                <pre><code>var parameters = new Dictionary&lt;string, string&gt;
{
    { "userName", "John" }
};
@@await Translaas.T("messages", "items", LanguageCodes.English, number: 5, parameters: parameters)</code></pre>
                <p>Translation with number and parameters: @itemsWithParams</p>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <h3>5. Multiple Languages</h3>
            </div>
            <div class="card-body">
                <p>Switching languages:</p>
                <ul>
                    <li>English (@LanguageCodes.English): @welcomeEn</li>
                    <li>French (@LanguageCodes.French): @welcomeFr</li>
                    <li>Spanish (@LanguageCodes.Spanish): @welcomeEs</li>
                </ul>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <h3>6. Dynamic Translation</h3>
            </div>
            <div class="card-body">
                <p>Dynamic translation based on component state:</p>
                <p>Current language: <strong>@currentLang</strong></p>
                <p>Translation: @currentWelcome</p>
                <button class="btn btn-primary" @onclick="ToggleLanguage">Toggle Language</button>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <h3>7. Translation Group (Bulk Operation)</h3>
            </div>
            <div class="card-body">
                <p><strong>Note:</strong> <code>GetGroupAsync()</code> is only available on <code>ITranslaasClient</code>, not <code>ITranslaasService</code>. For single entries, always use <code>Translaas.T()</code>.</p>
                @if (translationGroup != null)
                {
                    // Filter out metadata fields and only show actual translation entries
                    var translationEntries = translationGroup.Entries
                        .Where(e => e.Value.ValueKind == System.Text.Json.JsonValueKind.String)
                        .ToDictionary(e => e.Key, e => e.Value.GetString() ?? string.Empty);
                    
                    <p>Group 'common' contains @translationEntries.Count translation entries:</p>
                    <ul>
                        @foreach (var entry in translationEntries)
                        {
                            <li><strong>@entry.Key</strong>: @entry.Value</li>
                        }
                    </ul>
                }
                else
                {
                    <p>Loading translation group...</p>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private string currentLang = LanguageCodes.English;
    private TranslationGroup? translationGroup;
    
    // Translation strings loaded in OnInitializedAsync
    private string welcome = string.Empty;
    private string welcomeMessage = string.Empty;
    private string welcomeEn = string.Empty;
    private string welcomeFr = string.Empty;
    private string welcomeEs = string.Empty;
    private string itemSingular = string.Empty;
    private string itemPlural = string.Empty;
    private string currentWelcome = string.Empty;
    private string greetingWithParams = string.Empty;
    private string itemsWithParams = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            const string projectId = "translaas-sdk-samples";
            
            // Load all translations upfront
            welcome = await Translaas.T("common", "welcome", LanguageCodes.English);
            welcomeMessage = await Translaas.T("common", "welcome.message", LanguageCodes.English);
            welcomeEn = await Translaas.T("common", "welcome", LanguageCodes.English);
            welcomeFr = await Translaas.T("common", "welcome", LanguageCodes.French);
            welcomeEs = await Translaas.T("common", "welcome", LanguageCodes.Spanish);
            itemSingular = await Translaas.T("messages", "item", LanguageCodes.English, 1);
            itemPlural = await Translaas.T("messages", "item", LanguageCodes.English, 5);
            currentWelcome = await Translaas.T("common", "welcome", currentLang);
            
            // Named parameters example
            var parameters = new Dictionary<string, string>
            {
                { "userName", "John" },
                { "itemCount", "5" }
            };
            greetingWithParams = await Translaas.T("messages", "greeting", LanguageCodes.English, parameters: parameters);
            
            // Combining number and named parameters
            var userNameParams = new Dictionary<string, string>
            {
                { "userName", "John" }
            };
            itemsWithParams = await Translaas.T("messages", "items", LanguageCodes.English, number: 5, parameters: userNameParams);
            
            // Load translation group
            translationGroup = await TranslaasClient.GetGroupAsync(projectId, "common", LanguageCodes.English);
        }
        catch (Exception ex)
        {
            // Handle error - in production, log this
            Console.WriteLine($"Error loading translations: {ex.Message}");
        }
    }

    private async Task ToggleLanguage()
    {
        currentLang = currentLang == LanguageCodes.English ? LanguageCodes.French : LanguageCodes.English;
        currentWelcome = await Translaas.T("common", "welcome", currentLang);
        StateHasChanged();
    }
}
