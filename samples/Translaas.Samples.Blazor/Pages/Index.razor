@page "/"
@using System.Collections.Generic
@using Translaas.Models
@using Translaas.Models.Responses
@using L = Translaas.Models.LanguageCodes
@inject ITranslaasService Translaas
@inject ITranslaasClient TranslaasClient
@inject IConfiguration Configuration

<PageTitle>Home</PageTitle>

<h1>@welcome</h1>

<p>@welcomeMessage</p>

<div class="row mt-5">
    <div class="col-md-12">
        <h2>Translation Examples</h2>
        
        <div class="card mb-3">
            <div class="card-header">
                <h3>1. Direct Service Injection</h3>
            </div>
            <div class="card-body">
                <p>Using injected <code>ITranslaasService</code>:</p>
                <p><strong>With default language (from appsettings.json: @defaultLanguage):</strong></p>
                <pre><code>@@await Translaas.T("common", "welcome")</code></pre>
                <p>Result: @welcomeDefault</p>
                <p><strong>With explicit override:</strong></p>
                <pre><code>@@await Translaas.T("common", "welcome", L.English)</code></pre>
                <p>Result: @welcomeEn</p>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <h3>2. Pluralization</h3>
            </div>
            <div class="card-body">
                <p>Using pluralization with the <code>number</code> parameter:</p>
                <p><strong>With default language (from appsettings.json: @defaultLanguage):</strong></p>
                <pre><code>@@await Translaas.T("messages", "item", null, 1)
@@await Translaas.T("messages", "item", null, 5)</code></pre>
                <p>1 item: @itemSingular</p>
                <p>5 items: @itemPlural</p>
                <p><strong>With explicit override:</strong></p>
                <pre><code>@@await Translaas.T("messages", "item", L.English, 1)
@@await Translaas.T("messages", "item", L.English, 5)</code></pre>
                <p>1 item: @itemSingularOverride</p>
                <p>5 items: @itemPluralOverride</p>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <h3>3. Named Parameters</h3>
            </div>
            <div class="card-body">
                <p>Using named parameters with <code>ITranslaasService.T()</code>:</p>
                <p><strong>With default language (from appsettings.json: @defaultLanguage):</strong></p>
                <pre><code>var parameters = new Dictionary&lt;string, string&gt;
{
    { "userName", "John" },
    { "itemCount", "5" }
};
@@await Translaas.T("messages", "greeting", null, parameters: parameters)</code></pre>
                <p>Translation with parameters: @greetingWithParams</p>
                <p><strong>With explicit override:</strong></p>
                <pre><code>@@await Translaas.T("messages", "greeting", L.English, parameters: parameters)</code></pre>
                <p>Translation with parameters: @greetingWithParamsOverride</p>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <h3>4. Combining Number and Named Parameters</h3>
            </div>
            <div class="card-body">
                <p>Combining <code>number</code> and named parameters:</p>
                <p><strong>With default language (from appsettings.json: @defaultLanguage):</strong></p>
                <pre><code>var parameters = new Dictionary&lt;string, string&gt;
{
    { "userName", "John" }
};
@@await Translaas.T("messages", "items", null, number: 5, parameters: parameters)</code></pre>
                <p>Translation with number and parameters: @itemsWithParams</p>
                <p><strong>With explicit override:</strong></p>
                <pre><code>@@await Translaas.T("messages", "items", L.English, number: 5, parameters: parameters)</code></pre>
                <p>Translation with number and parameters: @itemsWithParamsOverride</p>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <h3>5. Multiple Languages</h3>
            </div>
            <div class="card-body">
                <p>Switching languages:</p>
                <ul>
                    <li>English (@L.English): @welcomeEn</li>
                    <li>French (@L.French): @welcomeFr</li>
                    <li>Spanish (@L.Spanish): @welcomeEs</li>
                </ul>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <h3>6. Dynamic Translation</h3>
            </div>
            <div class="card-body">
                <p>Dynamic translation based on component state:</p>
                <p>Current language: <strong>@currentLang</strong></p>
                <p>Translation: @currentWelcome</p>
                <button class="btn btn-primary" @onclick="ToggleLanguage">Toggle Language</button>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <h3>7. Translation Group (Bulk Operation)</h3>
            </div>
            <div class="card-body">
                <p><strong>Note:</strong> <code>GetGroupAsync()</code> is only available on <code>ITranslaasClient</code>, not <code>ITranslaasService</code>. For single entries, always use <code>Translaas.T()</code>.</p>
                @if (translationGroup != null)
                {
                    // Filter out metadata fields and only show actual translation entries
                    var translationEntries = translationGroup.Entries
                        .Where(e => e.Value.ValueKind == System.Text.Json.JsonValueKind.String)
                        .ToDictionary(e => e.Key, e => e.Value.GetString() ?? string.Empty);
                    
                    <p>Group 'common' contains @translationEntries.Count translation entries:</p>
                    <ul>
                        @foreach (var entry in translationEntries)
                        {
                            <li><strong>@entry.Key</strong>: @entry.Value</li>
                        }
                    </ul>
                }
                else
                {
                    <p>Loading translation group...</p>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private string defaultLanguage = string.Empty;
    private string currentLang = string.Empty;
    private TranslationGroup? translationGroup;
    
    // Translation strings loaded in OnInitializedAsync
    private string welcome = string.Empty;
    private string welcomeMessage = string.Empty;
    private string welcomeDefault = string.Empty;
    private string welcomeEn = string.Empty;
    private string welcomeFr = string.Empty;
    private string welcomeEs = string.Empty;
    private string itemSingular = string.Empty;
    private string itemPlural = string.Empty;
    private string itemSingularOverride = string.Empty;
    private string itemPluralOverride = string.Empty;
    private string currentWelcome = string.Empty;
    private string greetingWithParams = string.Empty;
    private string greetingWithParamsOverride = string.Empty;
    private string itemsWithParams = string.Empty;
    private string itemsWithParamsOverride = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            const string projectId = "translaas-sdk-samples";
            
            // Get default language from configuration
            defaultLanguage = Configuration["Translaas:DefaultLanguage"] ?? L.English;
            currentLang = defaultLanguage;
            
            // Load all translations upfront
            // Using default language from appsettings.json
            welcome = await Translaas.T("common", "welcome"); // Uses default language
            welcomeMessage = await Translaas.T("common", "welcome.message"); // Uses default language
            welcomeDefault = await Translaas.T("common", "welcome"); // Uses default language
            
            // Override examples
            welcomeEn = await Translaas.T("common", "welcome", L.English); // Explicit override
            welcomeFr = await Translaas.T("common", "welcome", L.French); // Explicit override
            welcomeEs = await Translaas.T("common", "welcome", L.Spanish); // Explicit override
            
            // Pluralization with default language
            itemSingular = await Translaas.T("messages", "item", null, 1); // Uses default language
            itemPlural = await Translaas.T("messages", "item", null, 5); // Uses default language
            
            // Pluralization with override
            itemSingularOverride = await Translaas.T("messages", "item", L.English, 1); // Explicit override
            itemPluralOverride = await Translaas.T("messages", "item", L.English, 5); // Explicit override
            
            currentWelcome = await Translaas.T("common", "welcome", currentLang);
            
            // Named parameters example with default language
            var parameters = new Dictionary<string, string>
            {
                { "userName", "John" },
                { "itemCount", "5" }
            };
            greetingWithParams = await Translaas.T("messages", "greeting", null, parameters: parameters); // Uses default language
            
            // Named parameters with override
            greetingWithParamsOverride = await Translaas.T("messages", "greeting", L.English, parameters: parameters); // Explicit override
            
            // Combining number and named parameters with default language
            var userNameParams = new Dictionary<string, string>
            {
                { "userName", "John" }
            };
            itemsWithParams = await Translaas.T("messages", "items", null, number: 5, parameters: userNameParams); // Uses default language
            
            // Combining number and named parameters with override
            itemsWithParamsOverride = await Translaas.T("messages", "items", L.English, number: 5, parameters: userNameParams); // Explicit override
            
            // Load translation group with default language
            translationGroup = await TranslaasClient.GetGroupAsync(projectId, "common", defaultLanguage);
        }
        catch (Exception ex)
        {
            // Handle error - in production, log this
            Console.WriteLine($"Error loading translations: {ex.Message}");
        }
    }

    private async Task ToggleLanguage()
    {
        currentLang = currentLang == defaultLanguage ? L.French : defaultLanguage;
        currentWelcome = await Translaas.T("common", "welcome", currentLang);
        StateHasChanged();
    }
}
