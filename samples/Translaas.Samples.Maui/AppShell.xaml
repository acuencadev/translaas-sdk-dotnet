<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Translaas.Samples.Maui.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Translaas.Samples.Maui.Views"
    Shell.FlyoutBehavior="Flyout"
    Title="Translaas Sample">

    <Shell.FlyoutHeader>
        <Grid HeightRequest="100" BackgroundColor="{StaticResource Primary}">
            <Label Text="Translaas SDK"
                   TextColor="White"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Grid>
    </Shell.FlyoutHeader>

    <FlyoutItem Title="Home" Icon="{OnPlatform Default='home.png'}">
        <ShellContent ContentTemplate="{DataTemplate views:MainPage}" Route="MainPage" />
    </FlyoutItem>

    <FlyoutItem Title="Settings" Icon="{OnPlatform Default='settings.png'}">
        <ShellContent ContentTemplate="{DataTemplate views:SettingsPage}" Route="SettingsPage" />
    </FlyoutItem>

</Shell>
