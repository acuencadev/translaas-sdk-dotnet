{
  "Translaas": {
    "ApiKey": "dummy-not-used-in-offline-mode",
    "BaseUrl": "https://api.translaas.com",
    "DefaultLanguage": "fr",
    "OfflineCache": {
      "Enabled": true,
      "CacheDirectory": "./cache",
      "FallbackMode": "CacheOnly",
      "AutoSync": false,
      "DefaultProjectId": "translaas-sdk-samples"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "System.Net.Http.HttpClient": "Warning"
    }
  }
}
